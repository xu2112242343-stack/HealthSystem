# 复制为 .env 后按本机修改（不要将 .env 提交到 Git）

# 方式一：分项配置（推荐，密码含 @ # 等符号时更安全）
HEALTH_MYSQL_HOST=127.0.0.1
HEALTH_MYSQL_PORT=3306
HEALTH_MYSQL_USER=root
HEALTH_MYSQL_PASSWORD=123123
HEALTH_MYSQL_DATABASE=health_platform

# 方式二：整条 URL（设置后忽略上面分项；密码需自行 URL 编码）
# HEALTH_DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/health_platform?charset=utf8mb4

# 首次启动且 admin_accounts 为空时自动插入一条管理员（生产务必改密）
# HEALTH_ADMIN_LOGIN=admin
# HEALTH_ADMIN_PASSWORD=admin123
# HEALTH_ADMIN_USERNAME=系统管理员

# 卒中影像 YOLO 权重（二选一；不设则在 stroke 下自动搜：results/.../yolov8s-seg、models/yolov8s-seg、weights 等）
# HEALTH_STROKE_YOLO_WEIGHTS=C:/path/to/best.pt
# HEALTH_STROKE_YOLO_DIR=C:/path/to/folder_with_pt
