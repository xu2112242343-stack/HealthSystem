# 复制为 .env.local 使用（勿将 .env.local 提交到仓库）
# 后端 API 根；示例 http://127.0.0.1:8001。留空则请求为相对路径（适合 Vite 代理）
VITE_API_BASE_URL=

# true=使用前端 mock / 本地演示数据；接后端后改为 false
VITE_USE_API_MOCK=true

# 设为 1 时工作台使用与管理端一致的演示统计（也可用 ?demo=1 / ?demo1=1）
# 本地 dev 已在 .env.development 默认开启
# VITE_DOCTOR_DEMO=1

# 请求头 X-Client-App，便于后端区分子应用
VITE_APP_NAME=doctor
